# Standalone admin-api settings (split-service mode).

#NAKAMA_HOST=<REMOTE_NAKAMA_HOST_OR_IP>
NAKAMA_HOST=localhost
NAKAMA_API_PORT=7350
NAKAMA_CONSOLE_PORT=7351
#TELEMETRY_MODE=async
#TELEMETRY_BUFFER_SIZE=200

# telemetry coupling mode: off / sync / async
TELEMETRY_MODE=async

# standalone telemetry service URL
TELEMETRY_API_BASE_URL=http://host.docker.internal:8200
# TELEMETRY_API_BASE_URL=http://localhost:8200